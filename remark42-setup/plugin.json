{
  "name": "remark42-setup",
  "description": "Install and manage Remark42 comment server",
  "version": "1.0.0",
  "entry": "main.py",
  "triggers": [
    {
      "type": "manual",
      "content": {
        "label": "Setup Remark42",
        "input": [
          { "name": "site_url", "label": "Site URL (empty = auto from hugo.toml baseURL)", "type": "text", "default": "" },
          { "name": "port", "label": "Port", "type": "text", "default": "8080" },
          { "name": "backup_path", "label": "Backup path (empty = {base}/remark42/db)", "type": "text", "default": "" }
        ]
      }
    },
    {
      "type": "manual",
      "content": {
        "label": "Restart Remark42",
        "input": []
      }
    }
  ]
}
